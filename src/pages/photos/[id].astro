---
import { ClientRouter } from "astro:transitions";
import styles from '../../components/PhotoDetail.module.css';
import { fetchAllPhotos, fetchPhoto } from '../../lib/api';
import '../../styles/global.css';

export async function getStaticPaths() {
  const photos = await fetchAllPhotos();
  return photos.map((photo) => ({
    params: { id: photo.id },
    props: { photo },
  }));
}

const { photo } = Astro.props;

const formattedDate = photo.taken_at
  ? new Date(photo.taken_at).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={photo.description ?? photo.title} />
    <title>{photo.title} — pics.ignaciofigueroa.dev</title>
    <ClientRouter />
  </head>
  <body>
    <div class={styles.page}>

      <!-- Full-screen image -->
      <div class={styles.imageContainer}>
        <img
          src={photo.image_url}
          alt={photo.title}
          class={styles.image}
          transition:name={`photo-img-${photo.id}`}
        />
      </div>

      <!-- Top bar: back + actions -->
      <div class={styles.topBar}>
        <a href="/" class={styles.backBtn}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Gallery
        </a>

        <div class={styles.topRight}>
          {photo.spotify_url && (
            <a
              href={photo.spotify_url}
              target="_blank"
              rel="noopener noreferrer"
              class={styles.spotifyBtn}
              aria-label="Listen on Spotify"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
              </svg>
              Playing on Spotify
            </a>
          )}

          {photo.favorite && (
            <div class={styles.favIcon} aria-label="Favorite photo">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
          )}
        </div>
      </div>

      <!-- Bottom metadata panel -->
      <div class={styles.panel}>
        <div class={styles.panelInner}>
          <h1 class={styles.title}>{photo.title}</h1>

          {photo.description && (
            <p class={styles.description}>{photo.description}</p>
          )}

          <div class={styles.tags}>
            <a href={`/categories/${photo.category.slug}`} class={styles.categoryTag}>
              {photo.category.name}
            </a>

            {photo.location && (
              <span class={styles.locationTag}>
                <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                </svg>
                {photo.location}
              </span>
            )}

            {formattedDate && (
              <span class={styles.dateTag}>{formattedDate}</span>
            )}
          </div>
        </div>
      </div>

    </div>
  </body>
</html>
