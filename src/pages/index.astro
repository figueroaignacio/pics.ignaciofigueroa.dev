---
import { ClientRouter } from "astro:transitions";
import Gallery from '../components/Gallery.astro';
import Header from '../components/Header.astro';
import { photos } from '../data/photos';
import '../styles/global.css';

const activeCategory = Astro.url.searchParams.get('category') ?? 'all';


const filtered = activeCategory === 'all'
  ? [...photos]
  : photos.filter(p => p.category.toLowerCase() === activeCategory.toLowerCase());

const shuffled = filtered.sort(() => Math.random() - 0.5);
const categories = [...new Set(photos.map(p => p.category))].sort();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="A curated masonry gallery of personal photography by Ignacio Figueroa." />
    <meta property="og:title" content="pics.ignaciofigueroa.dev" />
    <meta property="og:description" content="A curated masonry gallery of personal photography." />
    <meta property="og:type" content="website" />
    <title>pics.ignaciofigueroa.dev</title>
    <ClientRouter />
  </head>
  <body>
    <Header totalPhotos={filtered.length} />
    <Gallery photos={shuffled} categories={categories} activeCategory={activeCategory} />
  </body>
</html>
