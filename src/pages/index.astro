---
import Gallery from '../components/Gallery.astro';
import GalleryLayout from '../layouts/GalleryLayout.astro';
import { fetchAllPhotos, fetchCategories } from '../lib/api';

const [photos, categories] = await Promise.all([fetchAllPhotos(), fetchCategories()]);
const shuffled = [...photos].sort(() => Math.random() - 0.5);

const photosPerCategory = photos.reduce<Record<string, number>>((acc, photo) => {
  const slug = photo.category.slug;
  acc[slug] = (acc[slug] ?? 0) + 1;
  return acc;
}, {});
const filteredCategories = categories.filter((cat) => (photosPerCategory[cat.slug] ?? 0) > 1);
---

<GalleryLayout
  title="pics.ignaciofigueroa.dev"
  description="A curated masonry gallery of personal photography by Ignacio Figueroa."
  ogTitle="pics.ignaciofigueroa.dev"
  ogDescription="A curated masonry gallery of personal photography."
  totalPhotos={photos.length}
  categories={filteredCategories}
  activeCategory="all"
>
  <Gallery photos={shuffled} />
</GalleryLayout>
