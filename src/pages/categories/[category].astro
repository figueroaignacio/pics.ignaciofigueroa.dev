---
import Gallery from '../../components/Gallery.astro';
import GalleryLayout from '../../layouts/GalleryLayout.astro';
import { fetchAllPhotos, fetchCategories, fetchPhotosByCategory } from '../../lib/api';

export async function getStaticPaths() {
  const categories = await fetchCategories();
  return categories.map((cat) => ({
    params: { category: cat.slug },
    props: { categoryName: cat.name },
  }));
}

const { category } = Astro.params;
const { categoryName } = Astro.props;

const [photos, allCategories, allPhotos] = await Promise.all([
  fetchPhotosByCategory(category),
  fetchCategories(),
  fetchAllPhotos(),
]);

const shuffled = [...photos].sort(() => Math.random() - 0.5);

const photosPerCategory = allPhotos.reduce<Record<string, number>>((acc, photo) => {
  const slug = photo.category.slug;
  acc[slug] = (acc[slug] ?? 0) + 1;
  return acc;
}, {});
const filteredCategories = allCategories.filter((cat) => (photosPerCategory[cat.slug] ?? 0) > 1);
---

<GalleryLayout
  title={`${categoryName} · pics.ignaciofigueroa.dev`}
  description={`${categoryName} photography by Ignacio Figueroa.`}
  ogTitle={`${categoryName} · pics.ignaciofigueroa.dev`}
  ogDescription={`A curated ${categoryName} photography collection.`}
  totalPhotos={photos.length}
  categories={filteredCategories}
  activeCategory={category}
>
  <Gallery photos={shuffled} />
</GalleryLayout>
