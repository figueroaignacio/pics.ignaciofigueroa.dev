---
import Gallery from '../../components/Gallery.astro';
import GalleryLayout from '../../layouts/GalleryLayout.astro';
import { fetchCategories, fetchPhotosByCategory } from '../../lib/api';

export async function getStaticPaths() {
  const categories = await fetchCategories();
  return categories.map((cat) => ({
    params: { category: cat.slug },
    props: { categoryName: cat.name },
  }));
}

const { category } = Astro.params;
const { categoryName } = Astro.props;

const [photos, allCategories] = await Promise.all([
  fetchPhotosByCategory(category),
  fetchCategories(),
]);

const shuffled = [...photos].sort(() => Math.random() - 0.5);
---

<GalleryLayout
  title={`${categoryName} · pics.ignaciofigueroa.dev`}
  description={`${categoryName} photography by Ignacio Figueroa.`}
  ogTitle={`${categoryName} · pics.ignaciofigueroa.dev`}
  ogDescription={`A curated ${categoryName} photography collection.`}
  totalPhotos={photos.length}
  categories={allCategories}
  activeCategory={category}
>
  <Gallery photos={shuffled} />
</GalleryLayout>
