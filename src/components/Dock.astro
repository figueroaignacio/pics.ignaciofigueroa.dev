---
interface Props {
  categories: string[];
  activeCategory: string;
}

const { categories, activeCategory } = Astro.props;

const categoryIcons: Record<string, string> = {
  all:      '⚡',
  city:     '🏙️',
  memories: '📷',
  nature:   '🌿',
  night:    '🌙',
  random:   '🎲',
  travel:   '✈️',
};

function iconFor(cat: string) {
  return categoryIcons[cat.toLowerCase()] ?? '📁';
}

const items = [
  { label: 'All', href: '/', key: 'all' },
  ...categories.map(cat => ({
    label: cat,
    href: `/?category=${encodeURIComponent(cat)}`,
    key: cat.toLowerCase(),
  })),
];
---

<nav id="dock" class="dock" aria-label="Filter by category">
  {items.map(({ label, href, key }) => {
    const isActive = key === activeCategory.toLowerCase() || (key === 'all' && activeCategory === 'all');
    return (
      <a
        href={href}
        class={`dock-item${isActive ? ' active' : ''}`}
        aria-current={isActive ? 'page' : undefined}
        data-label={label}
      >
        <span class="dock-icon">{iconFor(key)}</span>
        <span class="dock-label">{label}</span>
      </a>
    );
  })}
</nav>

<style>
  .dock {
    position: fixed;
    bottom: 1.25rem;
    left: 50%;
    translate: -50% 0;
    z-index: 200;

    display: flex;
    align-items: flex-end;
    gap: 0.4rem;
    padding: 0.55rem 0.75rem;

    background: rgba(18, 18, 18, 0.72);
    backdrop-filter: blur(20px) saturate(1.8);
    -webkit-backdrop-filter: blur(20px) saturate(1.8);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1.4rem;
    box-shadow:
      0 8px 40px rgba(0, 0, 0, 0.6),
      0 0 0 0.5px rgba(255, 255, 255, 0.06) inset;
  }

  .dock-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    text-decoration: none;
    transform-origin: bottom center;
    transform: scale(1);
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .dock-item:hover {
    transform: scale(1.2);
  }

  .dock-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    font-size: 1.5rem;
    border-radius: 0.85rem;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .dock-item.active .dock-icon {
    background: rgba(96, 165, 250, 0.18);
    border-color: rgba(96, 165, 250, 0.45);
    box-shadow: 0 0 14px -2px rgba(96, 165, 250, 0.35);
  }

  /* Active indicator dot */
  .dock-item.active::after {
    content: '';
    position: absolute;
    bottom: -0.45rem;
    left: 50%;
    translate: -50% 0;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #60a5fa;
  }

  .dock-label {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    white-space: nowrap;
    transition: color 0.2s ease;
    pointer-events: none;
  }

  .dock-item.active .dock-label {
    color: #60a5fa;
  }

</style>
