---
import { Building2, Camera, Dices, FolderOpen, LayoutGrid, Leaf, Moon, Plane } from '@lucide/astro';
import Tooltip from './Tooltip.astro';
import type { ApiCategory } from '../lib/api';

interface Props {
  categories: ApiCategory[];
  activeCategory: string;
}

const { categories, activeCategory } = Astro.props;

const iconMap: Record<string, any> = {
  all: LayoutGrid,
  city: Building2,
  memories: Camera,
  nature: Leaf,
  night: Moon,
  random: Dices,
  travel: Plane,
};

const items = [
  { label: 'all', href: '/', key: 'all' },
  ...categories.map((cat) => ({
    label: cat.name,
    href: `/categories/${cat.slug}`,
    key: cat.slug,
  })),
];
---

<nav id="sidebar" class="sidebar" aria-label="Filter by category">
  <ul class="sidebar-nav" role="list">
    {
      items.map(({ label, href, key }) => {
        const isActive =
          key === activeCategory.toLowerCase() || (key === 'all' && activeCategory === 'all');
        const Icon = iconMap[key] ?? FolderOpen;
        return (
          <li>
            <a
              href={href}
              class={`sidebar-item${isActive ? ' active' : ''}`}
              aria-current={isActive ? 'page' : undefined}
            >
              <Tooltip label={label}>
                <span class="sidebar-icon">
                  <Icon size={18} stroke-width={1.5} />
                </span>
              </Tooltip>
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<style>
  .sidebar {
    position: fixed;
    left: 0;
    top: 0;
    bottom: 0;
    width: var(--sidebar-width, 72px);
    z-index: 200;
    overflow: visible;

    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;

    background: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-right: 1px dashed rgba(255, 255, 255, 0.06);
  }

  .sidebar-nav {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
    padding: 0;
    overflow: visible;
  }

  .sidebar-item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 0;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .sidebar-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    color: rgba(255, 255, 255, 0.3);
    transition: color 0.15s ease;
  }

  .sidebar-item:hover .sidebar-icon {
    color: rgba(255, 255, 255, 0.85);
  }

  .sidebar-item.active .sidebar-icon {
    color: #fff;
  }

  .sidebar-item.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20%;
    height: 60%;
    width: 1px;
    background: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 600px) {
    .sidebar {
      width: 52px;
    }

    .sidebar-item {
      padding: 0.65rem 0;
    }
  }
</style>
