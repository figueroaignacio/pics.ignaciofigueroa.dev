---
import type { Photo } from '../types/photo';
import styles from './Gallery.module.css';
import GalleryItem from './GalleryItem.astro';

interface Props {
  photos: Photo[];
  categories?: string[];
  activeCategory?: string;
}

const { photos, categories = [], activeCategory = 'all' } = Astro.props;
---

{categories.length > 0 && (
  <nav class={styles.filterBar} aria-label="Filter by category">
    <a
      href="/"
      class={`${styles.pill} ${activeCategory === 'all' ? styles.active : ''}`}
      aria-current={activeCategory === 'all' ? 'page' : undefined}
    >
      All
    </a>
    {categories.map(cat => {
      const isActive = cat.toLowerCase() === activeCategory.toLowerCase();
      return (
        <a
          href={`/?category=${encodeURIComponent(cat)}`}
          class={`${styles.pill} ${isActive ? styles.active : ''}`}
          aria-current={isActive ? 'page' : undefined}
        >
          {cat}
        </a>
      );
    })}
  </nav>
)}

<main class={styles.gallery} id="gallery-root">
  <div class={styles.masonry}>
    {photos.map((photo, index) => (
      <GalleryItem photo={photo} index={index} />
    ))}
  </div>
</main>

<script>
  // One-time entrance animation — skip on back/filter navigation
  document.addEventListener('astro:before-swap', (e) => {
    if (sessionStorage.getItem('gallery-animated')) {
      const incoming = (e as any).newDocument.getElementById('gallery-root');
      if (incoming) incoming.setAttribute('data-animated', '');
    }
  });

  document.addEventListener('astro:page-load', () => {
    sessionStorage.setItem('gallery-animated', '1');
  });
</script>
