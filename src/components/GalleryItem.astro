---
import type { Photo } from '../types/photo';
import styles from './GalleryItem.module.css';

interface Props {
  photo: Photo;
  index: number;
}

const { photo, index } = Astro.props;

const formattedDate = photo.taken_at
  ? new Date(photo.taken_at).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  : null;
---

<a
  href={`/photos/${photo.id}`}
  class={styles.item}
  style={`animation-delay: ${index * 65}ms`}
  aria-label={`View ${photo.title}`}
>
  <div class={styles.imageWrapper} style={`aspect-ratio: ${photo.aspectRatio}`}>
    <img
      src={photo.image_url}
      alt={photo.title}
      class={styles.image}
      loading={index < 6 ? 'eager' : 'lazy'}
      decoding="async"
      transition:name={`photo-img-${photo.id}`}
    />

    {photo.favorite && (
      <div class={styles.favBadge} aria-label="Favorite">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
      </div>
    )}

    <div class={styles.overlay}>
      <div class={styles.meta}>
        <p class={styles.title}>{photo.title}</p>
        <div class={styles.metaRow}>
          <span class={styles.category}>{photo.category}</span>
          {photo.location && (
            <span class={styles.location}>
              <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              {photo.location}
            </span>
          )}
          {formattedDate && <span class={styles.date}>{formattedDate}</span>}
        </div>
      </div>
    </div>
  </div>
</a>

<style>
  a {
    display: block;
  }
</style>
